(ns rasa.json)

(defn read-string
  "Reads a JSON string into Rasa data. JSON objects become maps with string keys."
  [s]
  (rasa.json.impl/read-string s))

(defn write-string
  "Writes supported Rasa data as a compact JSON string. Map keys must be strings."
  [value]
  (rasa.json.impl/write-string value))
