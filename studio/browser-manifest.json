{
  "runtime": "/rasa/runtime/ras.wasm",
  "sourceLibraries": [
    {
      "url": "./assets/rasa-libs/core.ras",
      "sourceId": "rasa://stdlib/lib/rasa/core.ras"
    },
    {
      "url": "./assets/rasa-libs/demo/music/notation.ras",
      "sourceId": "rasa://studio/demo.music.notation"
    },
    {
      "url": "./assets/rasa-libs/demo/music/score.ras",
      "sourceId": "rasa://studio/demo.music.score"
    }
  ],
  "session": {
    "initialNamespace": "rasa.core"
  },
  "packages": [
    {
      "package": "demo.tone-js",
      "url": "./assets/capabilities/demo.tone-js/package.ras"
    }
  ],
  "providers": [
    {
      "boundary": "ordinary-values",
      "effects": [
        "browser/audio-output"
      ],
      "toneCdn": "https://cdn.jsdelivr.net/npm/tone@15.1.22/+esm",
      "package": "demo.tone-js",
      "target": "wasm-browser",
      "kind": "browser-module",
      "module": "./providers/tone-provider.js"
    }
  ],
  "policy": {
    "allow": [
      "demo.tone-js/play!",
      "demo.tone-js/perform!"
    ]
  },
  "adapterBaseUrl": "/rasa/runtime/rasa-component/",
  "optimizedCallables": "./assets/optimized-callables/wasmgc-callables.json"
}
