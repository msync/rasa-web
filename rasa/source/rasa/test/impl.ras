(ns rasa.test.impl)

(defn collect
  "Returns a flat vector of assertion result maps from nested result values."
  [results]
  (loop [remaining (seq results)
         out []]
    (if remaining
      (let [result (first remaining)
            next-results (next remaining)]
        (recur next-results
               (if (nil? result)
                 out
                 (if (map? result)
                   (conj out result)
                   (if (coll? result)
                     (into out result)
                     out)))))
      out)))

(defn with-context
  "Adds a testing context label to each nested assertion result."
  [label results]
  (loop [remaining (seq results)
         out []]
    (if remaining
      (let [result (first remaining)
            contexts (get result :context [])]
        (recur (next remaining)
               (conj out (assoc result :context (conj contexts label)))))
      out)))
