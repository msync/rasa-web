{
  "runtime": "/assets/ras.wasm",
  "sourceLibraries": [
    "./assets/rasa-libs/core.ras",
    "./assets/rasa-libs/edn.ras",
    "./assets/rasa-libs/http.ras"
  ],
  "session": {
    "initialNamespace": "rasa.core"
  },
  "capabilityCatalogs": [
    {
      "package": "rasa.http",
      "url": "./assets/capabilities/rasa.http/catalog.ras"
    }
  ],
  "providers": [
    {
      "package": "rasa.http",
      "target": "wasm-browser",
      "kind": "browser-module",
      "module": "./providers/rasa-http-browser.js"
    }
  ],
  "policy": {
    "allow": [
      "rasa.http/request"
    ]
  }
}
